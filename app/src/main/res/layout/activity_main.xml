<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="#000000">

    <ScrollView
        android:id="@+id/terminal_scroll"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="112dip">

        <TextView
            android:id="@+id/terminal_output"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="8dip"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:typeface="monospace"
            android:gravity="top|left" />

    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#E6000000">

        <LinearLayout
            android:id="@+id/command_bar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dip">

            <EditText
                android:id="@+id/command_input"
                android:layout_width="0dip"
                android:layout_height="44dip"
                android:layout_weight="1"
                android:background="@drawable/edittext_terminal"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:hint="Command"
                android:textSize="16sp"
                android:typeface="monospace"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:paddingLeft="10dip"
                android:paddingRight="10dip" />

            <Button
                android:id="@+id/run_button"
                android:layout_width="wrap_content"
                android:layout_height="44dip"
                android:layout_marginLeft="6dip"
                android:background="@drawable/button_terminal"
                android:text="RUN"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:minWidth="70dip"
                android:minHeight="0dip"
                android:focusable="false"
                android:focusableInTouchMode="false" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>